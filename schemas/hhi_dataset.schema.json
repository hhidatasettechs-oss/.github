{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HHI OPS/Codex Dataset Metadata",
  "type": "object",
  "required": [
    "dataset_id",
    "dataset_name",
    "version",
    "authority",
    "license",
    "schema_type",
    "created_at",
    "files"
  ],
  "properties": {
    "dataset_id": { "type": "string", "minLength": 1 },
    "dataset_name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "authority": {
      "type": "string",
      "const": "Hollow House Institute"
    },
    "license": {
      "type": "string",
      "pattern": "^HHI[-_A-Z0-9\\.]+$"
    },
    "schema_type": {
      "type": "string",
      "enum": ["OPS", "Codex"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
